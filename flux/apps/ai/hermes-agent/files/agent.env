HOME=/opt/data
PATH=/opt/hermes/.venv/bin:/opt/data/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
TERMINAL_ENV=local
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_KEY=${AI_HERMES_API_SERVER_KEY}
HERMES_HOME=/opt/data
HERMES_DASHBOARD=1
HERMES_DASHBOARD_INSECURE=1
HERMES_TIMEZONE=${GLOBAL_TZ}
MATTERMOST_URL=http://mattermost.mattermost.svc.cluster.local:8065
MATTERMOST_HOME_CHANNEL=${AI_HERMES_MATTERMOST_HOME_CHANNEL}
MATTERMOST_ALLOWED_USERS=${AI_HERMES_MATTERMOST_ALLOWED_USERS}
SEARXNG_URL=http://searxng.searxng.svc.cluster.local:8080
